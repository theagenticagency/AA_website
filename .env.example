# HubSpot Waitlist Form Configuration
# See docs/tech-stack-recommendations/integrations/hubspot-lead-capture.md for setup instructions

# Your HubSpot Portal ID (find in Settings → Account Management)
VITE_HUBSPOT_PORTAL_ID=

# Your HubSpot Form GUID (create a form in Marketing → Forms, get ID from URL)
VITE_HUBSPOT_FORM_GUID=

# Staging Environment Protection
# Set this ONLY in the staging environment in Vercel
# Leave empty in production
VITE_STAGING_PASSWORD=
